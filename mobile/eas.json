{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://soft-rabbits-wait.loca.lt"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://soft-rabbits-wait.loca.lt"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://soft-rabbits-wait.loca.lt"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
