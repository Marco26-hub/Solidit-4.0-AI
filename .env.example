# ─────────────────────────────────────────────────────────────
# Solidità 4.0 — environment example. Copy to .env and edit.
# NEVER commit a real .env (secrets stay out of git).
# ─────────────────────────────────────────────────────────────

APP_ENV=local                       # local | staging | production
APP_NAME=Solidita 4.0
LOG_LEVEL=INFO

# --- Database -------------------------------------------------
# Runtime app connection: NON-superuser role -> RLS is enforced.
DATABASE_URL=postgresql+asyncpg://solidita_app:solidita_app@localhost:5432/solidita
# Migration connection: privileged role that owns/creates objects.
MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/solidita

# --- Redis (worker queue / cache, used from Sprint 3+) --------
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT -----------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- CORS (comma separated) -----------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Object storage (S3-compatible, used from Sprint 3+) ------
S3_ENDPOINT_URL=
S3_BUCKET=solidita-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-south-1
